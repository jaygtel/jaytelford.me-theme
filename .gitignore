# ----------------------
# Node.js
# ----------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
.pnpm-debug.log*

# Optional: keep lockfiles if you want reproducible builds
# !package-lock.json
# !yarn.lock

# Logs
logs
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
*.lcov

# Build output
dist/
build/
.next/
out/
.nuxt/

# Environment variables
.env
.env.*
!.env.example

# Cache
.cache/
.parcel-cache/
.eslintcache

# ----------------------
# Yarn (v2+ / Berry)
# ----------------------
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*
.yarnrc.yml

# ----------------------
# Ghost CMS
# ----------------------
# Content (usually user-generated, don’t commit)
content/images/
content/files/
content/media/

# Ghost database
content/data/*.db
content/data/*.db-journal

# Logs
content/logs/

# Themes (optional: ignore if developing themes separately)
# content/themes/

# Routes & config (keep if customised)
# content/settings/routes.yaml

# ----------------------
# JetBrains IDEs
# ----------------------
.idea/
*.iml
*.iws
out/

# JetBrains Fleet (if used)
.fleet/

# ----------------------
# macOS
# ----------------------
.DS_Store
.AppleDouble
.LSOverride

# Icon files
Icon?

# Thumbnails
._*

# Files that might appear on external disks
.Spotlight-V100
.Trashes

# ----------------------
# Misc
# ----------------------
.vscode/
*.swp
*.swo
*~

# Temporary files
tmp/
temp/

# OS generated
Thumbs.db